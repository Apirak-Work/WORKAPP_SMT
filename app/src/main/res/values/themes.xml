<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SMT" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.SMT" parent="Base.Theme.SMT" />

    <style name="WorkflowStep">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginHorizontal">3dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">4dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:singleLine">false</item>
    </style>

    <style name="WorkflowLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WorkflowValue">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:background">@drawable/bg_value_box</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WorkflowMeta">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:background">@drawable/bg_value_box</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="ProductionInfoCell">
        <item name="android:layout_width">256dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:background">@drawable/bg_info_cell</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingVertical">4dp</item>
    </style>

    <style name="ProductionInfoLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="ProductionInfoValue">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/link_blue</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="ActionModeButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginHorizontal">3dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProductionModeButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">38dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:paddingVertical">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="OperHeaderCell">
        <item name="android:layout_width">112dp</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:background">#DDE4EA</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">6dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="OperBodyCell">
        <item name="android:layout_width">112dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:background">@drawable/bg_info_cell</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">6dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:singleLine">true</item>
    </style>
</resources>
