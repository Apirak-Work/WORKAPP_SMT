<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutMergeFunction"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:background="@drawable/bg_info_cell"
    android:orientation="vertical"
    android:padding="10dp"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MERGE / COMBINE"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Add source runcards into one main runcard"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <Button
            android:id="@+id/mergeCloseButton"
            android:layout_width="82dp"
            android:layout_height="34dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="Close"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        style="@style/WorkflowLabel"
        android:layout_marginTop="10dp"
        android:text="Main Runcard" />

    <EditText
        android:id="@+id/mergeMainRuncardInput"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_value_box"
        android:hint="Main Runcard"
        android:inputType="textCapCharacters|textNoSuggestions"
        android:paddingHorizontal="10dp"
        android:singleLine="true"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        style="@style/WorkflowLabel"
        android:layout_marginTop="8dp"
        android:text="Source Runcard to Merge" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Spinner
            android:id="@+id/mergeSourceRuncardSpinner"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/bg_spinner_dropdown"
            android:paddingStart="10dp"
            android:paddingEnd="40dp"
            android:spinnerMode="dropdown" />

        <Button
            android:id="@+id/mergeAddSourceButton"
            android:layout_width="78dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="Add"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        style="@style/WorkflowLabel"
        android:layout_marginTop="10dp"
        android:text="SOURCE RUNCARDS" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                style="@style/OperHeaderCell"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Runcard" />

            <TextView
                style="@style/OperHeaderCell"
                android:layout_width="96dp"
                android:text="QTY" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mergeSourceRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="vertical" />

            <TextView
                android:id="@+id/mergeEmptyText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="No source runcards added"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/mergeTotalQtyText"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_value_box"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:text="Total Merged QTY: 0"
        android:textColor="@color/link_blue"
        android:textSize="14sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/mergeConfirmButton"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="10dp"
        android:text="Confirm Merge"
        android:textStyle="bold" />
</LinearLayout>
