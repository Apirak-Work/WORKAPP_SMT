<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/industrial_bg"
    android:focusable="true"
    android:focusableInTouchMode="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/stepper"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/stepScan"
            style="@style/WorkflowStep"
            android:text="1. Scan" />

        <TextView
            android:id="@+id/stepVerify"
            style="@style/WorkflowStep"
            android:text="2. Verify" />

        <TextView
            android:id="@+id/stepInput"
            style="@style/WorkflowStep"
            android:text="3. Input Qty" />

        <TextView
            android:id="@+id/stepSummary"
            style="@style/WorkflowStep"
            android:text="4. Summary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stepper">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/scanPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_panel"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SEQUENTIAL SCAN WORKFLOW"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/scannerStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_scan_target"
                    android:gravity="center"
                    android:minHeight="64dp"
                    android:text="Ready for User, Machine, or Runcard scan"
                    android:textColor="@color/teal_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <TextView
                        style="@style/WorkflowLabel"
                        android:text="User ID" />

                    <EditText
                        android:id="@+id/userIdInput"
                        style="@style/WorkflowValue"
                        android:hint="Scan or type User ID"
                        android:imeOptions="actionNext"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:singleLine="true" />

                    <TextView
                        style="@style/WorkflowLabel"
                        android:layout_marginTop="8dp"
                        android:text="Machine" />

                    <EditText
                        android:id="@+id/machineInput"
                        style="@style/WorkflowValue"
                        android:hint="Scan or type Machine"
                        android:imeOptions="actionNext"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:singleLine="true" />

                    <TextView
                        style="@style/WorkflowLabel"
                        android:layout_marginTop="8dp"
                        android:text="Runcard" />

                    <EditText
                        android:id="@+id/runcardInput"
                        style="@style/WorkflowValue"
                        android:hint="Scan or type Runcard"
                        android:imeOptions="actionDone"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:singleLine="true" />
                </LinearLayout>

                <Button
                    android:id="@+id/verifyButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:enabled="false"
                    android:text="VERIFY &amp; PROCEED"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/productionPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PRODUCTION DATA ENTRY"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fillViewport="false"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="horizontal">

                    <LinearLayout
                        android:id="@+id/productionDetailTable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout style="@style/ProductionInfoCell">
                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="#"
                                    android:textColor="@color/line_muted"
                                    android:textSize="22sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="DESCRIPTION" />

                                    <TextView
                                        android:id="@+id/descriptionValue"
                                        style="@style/ProductionInfoValue"
                                        android:text="?" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout style="@style/ProductionInfoCell">
                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="*"
                                    android:textColor="@color/line_muted"
                                    android:textSize="22sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="MATERIAL" />

                                    <TextView
                                        android:id="@+id/materialValue"
                                        style="@style/ProductionInfoValue"
                                        android:text="?" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout style="@style/ProductionInfoCell">
                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="[]"
                                    android:textColor="@color/line_muted"
                                    android:textSize="16sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="RC QUANTITY  (Qty RC / Qty WO)" />

                                    <TextView
                                        android:id="@+id/rcQuantityValue"
                                        style="@style/ProductionInfoValue"
                                        android:text="?" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout style="@style/ProductionInfoCell">
                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="@"
                                    android:textColor="@color/line_muted"
                                    android:textSize="22sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="DATECODE" />

                                    <TextView
                                        android:id="@+id/dateCodeValue"
                                        style="@style/ProductionInfoValue"
                                        android:text="?" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout style="@style/ProductionInfoCell">
                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text=">"
                                    android:textColor="@color/line_muted"
                                    android:textSize="22sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="WORK ORDER  MPQ :" />

                                    <TextView
                                        android:id="@+id/workOrderValue"
                                        style="@style/ProductionInfoValue"
                                        android:text="?" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout style="@style/ProductionInfoCell">
                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="&lt;&gt;"
                                    android:textColor="@color/line_muted"
                                    android:textSize="18sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="ASSY LOT" />

                                    <TextView
                                        android:id="@+id/assyLotValue"
                                        style="@style/ProductionInfoValue"
                                        android:text="?" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout style="@style/ProductionInfoCell">
                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="&lt;&gt;"
                                    android:textColor="@color/line_muted"
                                    android:textSize="18sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="WAFER LOT" />

                                    <TextView
                                        android:id="@+id/waferLotValue"
                                        style="@style/ProductionInfoValue"
                                        android:text="?" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout style="@style/ProductionInfoCell">
                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="[]"
                                    android:textColor="@color/line_muted"
                                    android:textSize="16sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="ORDER TYPE" />

                                    <TextView
                                        android:id="@+id/orderTypeValue"
                                        style="@style/ProductionInfoValue"
                                        android:text="?" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout style="@style/ProductionInfoCell">
                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="--"
                                    android:textColor="@color/line_muted"
                                    android:textSize="18sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="UOM" />

                                    <TextView
                                        android:id="@+id/uomValue"
                                        style="@style/ProductionInfoValue"
                                        android:text="?" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout style="@style/ProductionInfoCell">
                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="+"
                                    android:textColor="@color/line_muted"
                                    android:textSize="22sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="LOT TYPE" />

                                    <TextView
                                        android:id="@+id/lotTypeValue"
                                        style="@style/ProductionInfoValue"
                                        android:text="?" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                style="@style/ProductionInfoCell"
                                android:layout_width="512dp">

                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="/"
                                    android:textColor="@color/line_muted"
                                    android:textSize="22sp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        style="@style/ProductionInfoLabel"
                                        android:text="REEL NUMBER" />

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="28dp"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal">

                                        <EditText
                                            android:id="@+id/reelNumberInput"
                                            android:layout_width="0dp"
                                            android:layout_height="28dp"
                                            android:layout_weight="1"
                                            android:background="@drawable/bg_value_box"
                                            android:inputType="textCapCharacters|textNoSuggestions"
                                            android:paddingHorizontal="8dp"
                                            android:singleLine="true"
                                            android:textSize="12sp" />

                                        <Button
                                            android:id="@+id/reelNumberSaveButton"
                                            android:layout_width="76dp"
                                            android:layout_height="28dp"
                                            android:layout_marginStart="6dp"
                                            android:minHeight="0dp"
                                            android:minWidth="0dp"
                                            android:padding="0dp"
                                            android:text="save"
                                            android:textSize="11sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </HorizontalScrollView>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fillViewport="false"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/checkRuncardButton"
                            style="@style/ProductionModeButton"
                            android:text="CHECK RUNCARD" />

                        <Button
                            android:id="@+id/checkB2bButton"
                            style="@style/ProductionModeButton"
                            android:text="CHECK B2B" />

                        <Button
                            android:id="@+id/holdForIrrButton"
                            style="@style/ProductionModeButton"
                            android:text="HOLD for IRR : -" />

                        <Button
                            android:id="@+id/holdButton"
                            style="@style/ProductionModeButton"
                            android:text="HOLD" />

                        <Button
                            android:id="@+id/splitButton"
                            style="@style/ProductionModeButton"
                            android:text="SPLIT" />

                        <Button
                            android:id="@+id/mergeButton"
                            style="@style/ProductionModeButton"
                            android:text="MERGE/COMBINE" />

                        <Button
                            android:id="@+id/testButton"
                            style="@style/ProductionModeButton"
                            android:text="TEST" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="OPER TRACKING"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fillViewport="false"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="horizontal">

                    <LinearLayout
                        android:id="@+id/operRowsTable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/OperHeaderCell"
                                android:layout_width="64dp"
                                android:text="OPER" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:layout_width="72dp"
                                android:text="WC" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:layout_width="248dp"
                                android:text="DESCRIPTION" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:layout_width="140dp"
                                android:text="WorkCenter" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:text="RECEIVE" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:text="YIELD" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:text="SCRAP" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:text="MOVE" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:text="% YIELD" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:layout_width="156dp"
                                android:text="RECEIVE DATE" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:layout_width="156dp"
                                android:text="CONFIRM DATE" />

                            <TextView
                                style="@style/OperHeaderCell"
                                android:layout_width="72dp"
                                android:text="EN" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="64dp"
                                android:text="001" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="72dp"
                                android:text="WC01" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="248dp"
                                android:text="KIT PULL GENERATION"
                                android:textStyle="bold" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="140dp"
                                android:text="SMT LINE 01" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="1" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                android:id="@+id/kitPullReceiveDateValue"
                                style="@style/OperBodyCell"
                                android:layout_width="156dp"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="156dp"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="72dp"
                                android:text="-" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="64dp"
                                android:text="010" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="72dp"
                                android:text="WC01" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="248dp"
                                android:text="PRODUCTION INPUT QTY" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="140dp"
                                android:text="SMT LINE 01" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                android:id="@+id/operYieldValue"
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                android:id="@+id/operScrapValue"
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                android:id="@+id/operPercentYieldValue"
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="156dp"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="156dp"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="72dp"
                                android:text="-" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="64dp"
                                android:text="999" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="72dp"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="248dp"
                                android:text="* SUMMARY"
                                android:textColor="@color/link_blue"
                                android:textStyle="bold" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="140dp"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:text="-" />

                            <TextView
                                android:id="@+id/summaryPostingDateValue"
                                style="@style/OperBodyCell"
                                android:layout_width="156dp"
                                android:text="-" />

                            <TextView
                                android:id="@+id/summaryConfirmDateValue"
                                style="@style/OperBodyCell"
                                android:layout_width="156dp"
                                android:text="-" />

                            <TextView
                                style="@style/OperBodyCell"
                                android:layout_width="72dp"
                                android:text="-" />
                        </LinearLayout>
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    style="@style/WorkflowLabel"
                    android:layout_marginTop="12dp"
                    android:text="Good QTY" />

                <EditText
                    android:id="@+id/goodQtyInput"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_value_box"
                    android:imeOptions="actionNext"
                    android:inputType="number"
                    android:paddingHorizontal="12dp"
                    android:textSize="20sp" />

                <TextView
                    style="@style/WorkflowLabel"
                    android:layout_marginTop="8dp"
                    android:text="Scrap QTY" />

                <EditText
                    android:id="@+id/scrapQtyInput"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_value_box"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:paddingHorizontal="12dp"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/timestampValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_value_box"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="Start: 2026-05-27 09:30:00\nFinish: -\nPosting: -" />

                <Button
                    android:id="@+id/summaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="GO TO SUMMARY"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/saveButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:enabled="false"
                    android:text="SAVE CONFIRM"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
