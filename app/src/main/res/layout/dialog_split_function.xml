<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/panel_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SPLIT FUNCTION"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_value_box"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            style="@style/WorkflowLabel"
            android:text="CURRENT DATA" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/splitCurrentRuncard"
                style="@style/ProductionInfoValue"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:ellipsize="none"
                android:maxLines="2"
                android:singleLine="false"
                android:text="RC: -" />

            <TextView
                android:id="@+id/splitCurrentAssy"
                style="@style/ProductionInfoValue"
                android:layout_width="0dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="none"
                android:maxLines="2"
                android:singleLine="false"
                android:text="ASSY: -" />

            <TextView
                android:id="@+id/splitCurrentQty"
                style="@style/ProductionInfoValue"
                android:layout_width="92dp"
                android:layout_marginStart="8dp"
                android:text="QTY: -" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#EAF5FF"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            style="@style/WorkflowLabel"
            android:text="NEW DATA" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/splitNewRuncardPreview"
                style="@style/ProductionInfoValue"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:ellipsize="none"
                android:maxLines="2"
                android:singleLine="false"
                android:text="260604XXXX"
                android:textColor="@color/danger" />

            <TextView
                android:id="@+id/splitNewAssyPreview"
                style="@style/ProductionInfoValue"
                android:layout_width="0dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="none"
                android:maxLines="2"
                android:singleLine="false"
                android:text="ASSY-A"
                android:textColor="@color/danger" />

            <EditText
                android:id="@+id/splitNewQtyInput"
                android:layout_width="96dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_value_box"
                android:hint="New Qty"
                android:inputType="number"
                android:paddingHorizontal="8dp"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        style="@style/WorkflowLabel"
        android:layout_marginTop="10dp"
        android:text="SPLIT HISTORY TABLE" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="6dp"
        android:fillViewport="false"
        android:scrollbars="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    style="@style/OperHeaderCell"
                    android:layout_width="128dp"
                    android:text="Runcard" />

                <TextView
                    style="@style/OperHeaderCell"
                    android:layout_width="150dp"
                    android:text="AssyLot" />

                <TextView
                    style="@style/OperHeaderCell"
                    android:layout_width="72dp"
                    android:text="Qty" />

                <TextView
                    style="@style/OperHeaderCell"
                    android:layout_width="128dp"
                    android:text="Mother" />

                <TextView
                    style="@style/OperHeaderCell"
                    android:layout_width="92dp"
                    android:text="MotherQty" />

                <TextView
                    style="@style/OperHeaderCell"
                    android:layout_width="86dp"
                    android:text="WC" />

                <TextView
                    style="@style/OperHeaderCell"
                    android:layout_width="156dp"
                    android:text="Cdate" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/splitHistoryRecyclerView"
                android:layout_width="812dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="vertical" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/splitAddButton"
            android:layout_width="120dp"
            android:layout_height="46dp"
            android:text="Add Split"
            android:textStyle="bold" />

        <Button
            android:id="@+id/splitCloseButton"
            android:layout_width="96dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/line_muted"
            android:text="Close"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
